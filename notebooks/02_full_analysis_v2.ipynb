   "source": [
    "# Cell 10: Visualization of Monte Carlo results\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(22, 7))\n",
    "colors = {\"Pessimistic\": \"#e74c3c\", \"Baseline\": \"#3498db\", \"Optimistic\": \"#2ecc71\"}\n",
    "\n",
    "# \u2500\u2500 1. Cumulative Revenue Fan Chart \u2500\u2500\n",
    "ax = axes[0]\n",
    "quarters = np.arange(1, QUARTERS_AHEAD + 1)\n",
    "for name, r in results.items():\n",
    "    cum = r[\"cumulative\"]\n",
    "    median = np.median(cum, axis=0)\n",
    "    p5  = np.percentile(cum, 5, axis=0)\n",
    "    p95 = np.percentile(cum, 95, axis=0)\n",
    "    p25 = np.percentile(cum, 25, axis=0)\n",
    "    p75 = np.percentile(cum, 75, axis=0)\n",
    "    \n",
    "    ax.fill_between(quarters, p5, p95, alpha=0.1, color=colors[name])\n",
    "    ax.fill_between(quarters, p25, p75, alpha=0.25, color=colors[name])\n",
    "    ax.plot(quarters, median, linewidth=2.5, color=colors[name], label=name)\n",
    "\n",
    "ax.set_title(\"Cumulative Net Revenue Recovery\", fontweight=\"bold\", fontsize=13)\n",
    "ax.set_xlabel(\"Quarter\")\n",
    "ax.set_ylabel(\"Cumulative Net Revenue ($)\")\n",
    "ax.legend(fontsize=11)\n",
    "ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, _: f\"${x:,.0f}\"))\n",
    "\n",
    "# \u2500\u2500 2. Final Distribution \u2500\u2500\n",
    "ax = axes[1]\n",
    "for name, r in results.items():\n",
    "    final = r[\"cumulative\"][:, -1]\n",
    "    ax.hist(final, bins=50, alpha=0.5, color=colors[name], label=name, edgecolor=\"white\")\n",
    "    ax.axvline(np.median(final), color=colors[name], linestyle=\"--\", linewidth=1.5)\n",
    "\n",
    "ax.set_title(f\"Distribution of {QUARTERS_AHEAD}-Quarter Total Recovery\", fontweight=\"bold\", fontsize=13)\n",
    "ax.set_xlabel(\"Total Net Revenue ($)\")\n",
    "ax.set_ylabel(\"Frequency\")\n",
    "ax.legend()\n",
    "ax.xaxis.set_major_formatter(plt.FuncFormatter(lambda x, _: f\"${x:,.0f}\"))\n",
    "\n",
    "# \u2500\u2500 3. Quarterly Boxplots \u2500\u2500\n",
    "ax = axes[2]\n",
    "bp_data = []\n",
    "bp_labels = []\n",
    "bp_colors_list = []\n",
    "for name, r in results.items():\n",
    "    bp_data.append(r[\"quarterly\"].mean(axis=1))  # avg quarterly per sim\n",
    "    bp_labels.append(name)\n",
    "    bp_colors_list.append(colors[name])\n",
    "\n",
    "bp = ax.boxplot(bp_data, labels=bp_labels, patch_artist=True, widths=0.5)\n",
    "for patch, color in zip(bp[\"boxes\"], bp_colors_list):\n",
    "    patch.set_facecolor(color)\n",
    "    patch.set_alpha(0.6)\n",
    "ax.set_title(\"Avg Quarterly Revenue per Simulation\", fontweight=\"bold\", fontsize=13)\n",
    "ax.set_ylabel(\"Net Revenue ($)\")\n",
    "ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, _: f\"${x:,.0f}\"))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"monte_carlo_results.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "\n",
    "print(\"\u2705 Pipeline complete. Outputs saved:\")\n",
