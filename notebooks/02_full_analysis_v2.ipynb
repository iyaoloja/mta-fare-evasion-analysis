    "# Cell 7: Regression \u2014 Operational predictors of evasion rate\n",
    "\n",
    "feature_candidates = [\"otp_score\",\"crowding_index\",\"omny_adoption_rate\",\n",
    "                      \"service_delivery_rate\",\"service_frequency_idx\"]\n",
    "features = [f for f in feature_candidates if f in q.columns and q[f].notna().sum() > 30]\n",
    "target = \"evasion_rate\"\n",
    "\n",
    "print(f\"Regression features: {features}\")\n",
    "print(f\"Target: {target}\\n\")\n",
    "\n",
    "reg_df = q[features + [target]].dropna()\n",
    "X = reg_df[features]\n",
    "y = reg_df[target]\n",
    "\n",
    "# \u2500\u2500 Standardize \u2500\u2500\n",
    "scaler = StandardScaler()\n",
    "X_scaled = pd.DataFrame(scaler.fit_transform(X), columns=features, index=X.index)\n",
    "\n",
    "# \u2500\u2500 OLS with statsmodels (full diagnostics) \u2500\u2500\n",
    "X_ols = sm.add_constant(X_scaled)\n",
    "ols_model = sm.OLS(y, X_ols).fit()\n",
    "print(ols_model.summary())\n",
    "\n",
    "# \u2500\u2500 VIF check for multicollinearity \u2500\u2500\n",
    "print(\"\\n\u2500\u2500 Variance Inflation Factors \u2500\u2500\")\n",
    "for i, f in enumerate(features):\n",
    "    vif = variance_inflation_factor(X_scaled.values, i)\n",
    "    flag = \" \u26a0\ufe0f HIGH\" if vif > 5 else \"\"\n",
    "    print(f\"  {f:<30} VIF = {vif:.2f}{flag}\")\n",
    "\n",
    "# \u2500\u2500 Regularized models \u2500\u2500\n",
    "X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.2, random_state=42)\n",
    "\n",
    "models = {\n",
    "    \"OLS\":     LinearRegression(),\n",
    "    \"Ridge\":   Ridge(alpha=1.0),\n",
    "    \"Lasso\":   Lasso(alpha=0.01),\n",
    "    \"RF\":      RandomForestRegressor(n_estimators=200, max_depth=8, random_state=42),\n",
    "}\n",
    "\n",
    "print(\"\\n\u2500\u2500 Regression Model Comparison \u2500\u2500\")\n",
    "print(f\"  {'Model':<12} {'Train R\u00b2':>10} {'Test R\u00b2':>10} {'Test RMSE':>10}\")\n",
    "print(\"  \" + \"-\" * 45)\n",
    "\n",
    "for name, model in models.items():\n",
    "    model.fit(X_train, y_train)\n",
    "    train_r2 = model.score(X_train, y_train)\n",
    "    test_r2  = model.score(X_test, y_test)\n",
    "    y_pred   = model.predict(X_test)\n",
    "    rmse     = np.sqrt(mean_squared_error(y_test, y_pred))\n",
    "    print(f\"  {name:<12} {train_r2:>10.4f} {test_r2:>10.4f} {rmse:>10.4f}\")\n",
    "\n",
    "# \u2500\u2500 Feature importances (RF) \u2500\u2500\n",
    "rf_model = models[\"RF\"]\n",
    "importances = pd.Series(rf_model.feature_importances_, index=features).sort_values(ascending=True)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "importances.plot.barh(ax=ax, color=\"#3498db\", edgecolor=\"white\")\n",
    "ax.set_title(\"Random Forest \u2014 Feature Importances for Evasion Rate\", fontweight=\"bold\")\n",
    "ax.set_xlabel(\"Importance\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"regression_importances.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n"
