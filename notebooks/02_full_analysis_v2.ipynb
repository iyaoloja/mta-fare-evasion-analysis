   "source": [
    "# Cell 5: Engineer features and build unified quarterly table\n",
    "# \u2500\u2500\u2500 FIX: Group by route + yr_qtr (not just route) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "# Previously all rows collapsed to 1970-Q1 because date parsing was broken.\n",
    "# Now yr_qtr is correctly built, so we get one row per route per quarter.\n",
    "# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "\n",
    "route_key = 'route_clean' if 'route_clean' in df.columns else (COL.get('route') or df.columns[0])\n",
    "\n",
    "# \u2500\u2500 Group by route AND time period \u2500\u2500\n",
    "if 'yr_qtr' in df.columns:\n",
    "    group_cols = [route_key, 'yr_qtr', 'year', 'quarter']\n",
    "    print(f\"\u2705 Grouping by: {group_cols}\")\n",
    "    print(f\"   Unique quarters in data: {sorted(df['yr_qtr'].unique().tolist())}\")\n",
    "else:\n",
    "    group_cols = [route_key]\n",
    "    print(\"\u26a0\ufe0f  No yr_qtr \u2014 grouping by route only (check Fix 1)\")\n",
    "\n",
    "# \u2500\u2500 Helper: safe aggregation \u2500\u2500\n",
    "def safe_agg(series, func='mean'):\n",
    "    s = series.dropna()\n",
    "    if len(s) == 0:\n",
    "        return np.nan\n",
    "    return getattr(s, func)()\n",
    "\n",
    "agg_dict = {}\n",
    "\n",
    "if 'total_trips' in COL:\n",
    "    agg_dict[COL['total_trips']] = ['sum', 'mean', 'count']\n",
    "if 'scheduled_trips' in COL:\n",
    "    agg_dict[COL['scheduled_trips']] = 'sum'\n",
    "if 'ridership' in COL:\n",
    "    agg_dict[COL['ridership']] = ['sum', 'mean']\n",
    "if 'otp' in COL:\n",
    "    agg_dict[COL['otp']] = 'mean'\n",
    "if 'wait_assessment' in COL:\n",
    "    agg_dict[COL['wait_assessment']] = 'mean'\n",
    "if 'mean_distance_bf' in COL:\n",
    "    agg_dict[COL['mean_distance_bf']] = 'mean'\n",
    "if 'fare_evasion' in COL:\n",
    "    agg_dict[COL['fare_evasion']] = 'mean'\n",
    "if 'omny_taps' in COL:\n",
    "    agg_dict[COL['omny_taps']] = ['sum', 'mean']\n",
    "if 'metrocard_swipes' in COL:\n",
    "    agg_dict[COL['metrocard_swipes']] = ['sum', 'mean']\n",
    "if 'fare_revenue' in COL:\n",
    "    agg_dict[COL['fare_revenue']] = 'sum'\n",
    "\n",
    "if agg_dict:\n",
    "    quarterly = df.groupby(group_cols).agg(agg_dict).reset_index()\n",
    "    quarterly.columns = ['_'.join(c).strip('_') if isinstance(c, tuple) else c\n",
    "                         for c in quarterly.columns]\n",
    "else:\n",
    "    quarterly = df.groupby(group_cols).size().reset_index(name='record_count')\n",
    "\n",
    "print(f\"\\nQuarterly table: {quarterly.shape}\")\n",
    "print(f\"Expected: ~{df[route_key].nunique()} routes \u00d7 {df['yr_qtr'].nunique() if 'yr_qtr' in df.columns else 1} quarters\")\n",
    "print(f\"\\nSample:\")\n",
    "quarterly.head(8)\n"
   ]
  },
