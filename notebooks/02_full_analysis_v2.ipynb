   "source": [
    "# Cell 4: Clean and standardize\n",
    "# \u2500\u2500\u2500 FIXES APPLIED \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "# FIX 1: Use year + quarters columns for date parsing (avoids 1970 epoch bug)\n",
    "# FIX 2: Divide percentage columns by 100 after stripping % sign\n",
    "# FIX 3: wait_assessment also treated as percentage \u2014 divide by 100\n",
    "# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "\n",
    "df = df_raw.copy()\n",
    "\n",
    "# \u2500\u2500 FIX 1: Build yr_qtr from existing year + quarters columns \u2500\u2500\n",
    "# The raw 'month' column is an integer (1-12), NOT a date.\n",
    "# Parsing it with pd.to_datetime() defaults to 1970 \u2014 that's the bug.\n",
    "# Instead, use the 'year' and 'quarters' columns already in the dataset.\n",
    "if 'year' in df.columns and 'quarters' in df.columns:\n",
    "    df['yr_qtr']  = df['year'].astype(str) + '-' + df['quarters'].astype(str)\n",
    "    df['quarter'] = df['quarters'].astype(str).str.replace('Q', '', regex=False).astype(int)\n",
    "    print(f\"\u2705 yr_qtr built from year + quarters columns\")\n",
    "    print(f\"   Sample: {df['yr_qtr'].unique()[:6].tolist()}\")\n",
    "    print(f\"   Range : {df['yr_qtr'].min()} \u2192 {df['yr_qtr'].max()}\")\n",
    "else:\n",
    "    print(\"\u26a0\ufe0f  year/quarters columns not found \u2014 check column names\")\n",
    "\n",
    "# \u2500\u2500 Standardize route identifier \u2500\u2500\n",
    "route_col = COL.get('route', None)\n",
    "if route_col:\n",
    "    df['route_clean'] = df[route_col].astype(str).str.strip().str.upper()\n",
    "\n",
    "# \u2500\u2500 FIX 2: Convert numeric columns, handling % signs AND dividing by 100 \u2500\u2500\n",
    "# Columns that are TRUE RATES (0-100% \u2192 should become 0.0-1.0)\n",
    "pct_rate_keys = ['otp', 'wait_assessment', 'fare_evasion']\n",
    "\n",
    "# Columns that are raw counts (commas only, no division)\n",
    "count_keys = ['ridership', 'total_trips', 'scheduled_trips',\n",
    "              'omny_taps', 'metrocard_swipes', 'fare_revenue', 'mean_distance_bf']\n",
    "\n",
    "for key in pct_rate_keys:\n",
    "    if key in COL:\n",
    "        col = COL[key]\n",
    "        df[col] = (\n",
    "            df[col].astype(str)\n",
    "            .str.replace('%', '', regex=False)\n",
    "            .str.replace(',', '', regex=False)\n",
    "            .str.strip()\n",
    "        )\n",
    "        df[col] = pd.to_numeric(df[col], errors='coerce') / 100  # \u2190 KEY FIX\n",
    "        valid = df[col].notna().sum()\n",
    "        print(f\"   {col:<40} \u2192 min={df[col].min():.3f}  max={df[col].max():.3f}  ({valid} valid rows)\")\n",
    "\n",
    "for key in count_keys:\n",
    "    if key in COL:\n",
    "        col = COL[key]\n",
    "        df[col] = (\n",
    "            df[col].astype(str)\n",
    "            .str.replace('%', '', regex=False)\n",
    "            .str.replace(',', '', regex=False)\n",
    "            .str.strip()\n",
    "        )\n",
    "        df[col] = pd.to_numeric(df[col], errors='coerce')\n",
    "\n",
    "# \u2500\u2500 Drop fully empty rows \u2500\u2500\n",
    "before = len(df)\n",
    "df.dropna(how='all', inplace=True)\n",
    "print(f\"\\nDropped {before - len(df)} fully-empty rows.\")\n",
    "print(f\"Cleaned shape: {df.shape}\")\n",
    "\n",
    "# \u2500\u2500 Sanity check: evasion rate should be between 0 and 1 \u2500\u2500\n",
    "if 'fare_evasion' in COL:\n",
    "    ev_col = COL['fare_evasion']\n",
    "    bad = (df[ev_col] > 1).sum()\n",
    "    if bad > 0:\n",
    "        print(f\"\\n\u26a0\ufe0f  {bad} rows still have evasion_rate > 1 \u2014 check source data\")\n",
    "    else:\n",
    "        print(f\"\\n\u2705 Evasion rate sanity check passed \u2014 all values between 0 and 1\")\n",
    "\n",
    "# \u2500\u2500 Missing-value summary \u2500\u2500\n",
    "miss = df.isnull().sum()\n",
    "miss_pct = 100 * miss / len(df)\n",
