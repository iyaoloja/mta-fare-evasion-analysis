   "source": [
    "# Cell 5b: Derived features\n",
    "\n",
    "q = quarterly.copy()\n",
    "\n",
    "# \u2500\u2500 Service Frequency Index \u2500\u2500\n",
    "if \"scheduled_trips\" in COL and \"total_trips\" in COL:\n",
    "    sched_col = [c for c in q.columns if COL[\"scheduled_trips\"] in c and \"sum\" in c]\n",
    "    actual_col = [c for c in q.columns if COL[\"total_trips\"] in c and \"sum\" in c]\n",
    "    if sched_col and actual_col:\n",
    "        q[\"service_delivery_rate\"] = q[actual_col[0]] / q[sched_col[0]].replace(0, np.nan)\n",
    "        q[\"service_frequency_idx\"] = q[actual_col[0]]  # absolute frequency\n",
    "\n",
    "# \u2500\u2500 Crowding Proxy \u2500\u2500\n",
    "ridership_cols = [c for c in q.columns if \"ridership\" in c.lower() and \"sum\" in c.lower()]\n",
    "trip_sum_cols  = [c for c in q.columns if COL.get(\"total_trips\",\"XXX\") in c and \"sum\" in c]\n",
    "if ridership_cols and trip_sum_cols:\n",
    "    q[\"crowding_index\"] = q[ridership_cols[0]] / q[trip_sum_cols[0]].replace(0, np.nan)\n",
    "\n",
    "# \u2500\u2500 OMNY Adoption Rate \u2500\u2500\n",
    "omny_cols = [c for c in q.columns if \"omny\" in c.lower() and \"sum\" in c.lower()]\n",
    "if omny_cols and ridership_cols:\n",
    "    q[\"omny_adoption_rate\"] = q[omny_cols[0]] / q[ridership_cols[0]].replace(0, np.nan)\n",
    "elif omny_cols and trip_sum_cols:\n",
    "    q[\"omny_adoption_rate\"] = q[omny_cols[0]] / q[trip_sum_cols[0]].replace(0, np.nan)\n",
    "\n",
    "# \u2500\u2500 OTP Feature \u2500\u2500\n",
    "otp_cols = [c for c in q.columns if \"otp\" in c.lower() or \"on_time\" in c.lower()]\n",
    "if otp_cols:\n",
    "    q[\"otp_score\"] = q[otp_cols[0]]\n",
    "\n",
    "# \u2500\u2500 Evasion Target \u2500\u2500\n",
    "evasion_cols = [c for c in q.columns if \"evasion\" in c.lower()]\n",
    "if evasion_cols:\n",
    "    q[\"evasion_rate\"] = q[evasion_cols[0]]\n",
    "    q[\"high_evasion\"] = (q[\"evasion_rate\"] > q[\"evasion_rate\"].median()).astype(int)\n",
    "else:\n",
    "    # \u2500\u2500 SYNTHESIZE fare-evasion proxy if not in data \u2500\u2500\n",
    "    print(\"\u26a0\ufe0f  No evasion column found \u2014 synthesizing proxy from ridership vs fare data.\")\n",
    "    if ridership_cols and omny_cols:\n",
    "        mc_cols = [c for c in q.columns if \"metrocard\" in c.lower() and \"sum\" in c.lower()]\n",
    "        if mc_cols:\n",
    "            q[\"paid_ridership\"] = q[omny_cols[0]] + q[mc_cols[0]]\n",
    "        else:\n",
    "            q[\"paid_ridership\"] = q[omny_cols[0]]\n",
    "        q[\"evasion_rate\"] = 1 - (q[\"paid_ridership\"] / q[ridership_cols[0]].replace(0, np.nan))\n",
    "        q[\"evasion_rate\"] = q[\"evasion_rate\"].clip(0, 1)\n",
    "    else:\n",
    "        np.random.seed(42)\n",
    "        q[\"evasion_rate\"] = np.random.beta(2, 8, size=len(q))\n",
    "        print(\"   \u2192 Used synthetic beta-distributed evasion rates for modeling demo.\")\n",
    "    q[\"high_evasion\"] = (q[\"evasion_rate\"] > q[\"evasion_rate\"].median()).astype(int)\n",
    "\n",
    "# \u2500\u2500 Summary \u2500\u2500\n",
    "eng_features = [c for c in q.columns if c in [\n",
    "    \"service_delivery_rate\",\"service_frequency_idx\",\"crowding_index\",\n",
    "    \"omny_adoption_rate\",\"otp_score\",\"evasion_rate\",\"high_evasion\"]]\n",
    "print(f\"\\n\u2705 Engineered features: {eng_features}\")\n",
    "print(f\"   Quarterly table shape: {q.shape}\")\n",
    "q.describe()\n"
   ]
  },
