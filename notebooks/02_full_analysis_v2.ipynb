    "if \"otp_score\" in q.columns:\n",
    "    axes[0,1].scatter(q[\"otp_score\"], q[\"evasion_rate\"], alpha=0.3, c=\"#3498db\", s=15)\n",
    "    axes[0,1].set_title(\"Evasion vs On-Time Performance\")\n",
    "    axes[0,1].set_xlabel(\"OTP Score\")\n",
    "    axes[0,1].set_ylabel(\"Evasion Rate\")\n",
    "else:\n",
    "    axes[0,1].text(0.5, 0.5, \"No OTP data\", ha=\"center\", va=\"center\")\n",
    "\n",
    "# 3. Evasion vs Crowding\n",
    "if \"crowding_index\" in q.columns:\n",
    "    axes[0,2].scatter(q[\"crowding_index\"], q[\"evasion_rate\"], alpha=0.3, c=\"#2ecc71\", s=15)\n",
    "    axes[0,2].set_title(\"Evasion vs Crowding Index\")\n",
    "    axes[0,2].set_xlabel(\"Crowding Index\")\n",
    "else:\n",
    "    axes[0,2].text(0.5, 0.5, \"No crowding data\", ha=\"center\", va=\"center\")\n",
    "\n",
    "# 4. OMNY adoption vs evasion\n",
    "if \"omny_adoption_rate\" in q.columns:\n",
    "    axes[1,0].scatter(q[\"omny_adoption_rate\"], q[\"evasion_rate\"], alpha=0.3, c=\"#9b59b6\", s=15)\n",
    "    axes[1,0].set_title(\"Evasion vs OMNY Adoption\")\n",
    "    axes[1,0].set_xlabel(\"OMNY Adoption Rate\")\n",
    "else:\n",
    "    axes[1,0].text(0.5, 0.5, \"No OMNY data\", ha=\"center\", va=\"center\")\n",
    "\n",
    "# 5. High-evasion class balance\n",
    "q[\"high_evasion\"].value_counts().plot.bar(ax=axes[1,1], color=[\"#27ae60\",\"#e74c3c\"], edgecolor=\"white\")\n",
    "axes[1,1].set_title(\"High vs Low Evasion Routes\")\n",
    "axes[1,1].set_xticklabels([\"Low\",\"High\"], rotation=0)\n",
