   "source": [
    "# Cell 9: Monte Carlo Simulation \u2014 Revenue Recovery Scenarios\n",
    "# \u2500\u2500\u2500 FIX: Evasion rate is now 0-1 (not 0-100) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "# Previously evasion_rate was ~32x (3200%) because % was not divided by 100.\n",
    "# Now correctly between 0 and 1. Revenue figures will reflect real MTA scale.\n",
    "# Anchored to CBC-reported $918M annual loss (2024) for realism check.\n",
    "# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "\n",
    "FARE             = 2.90        # Current MTA base fare\n",
    "N_SIMULATIONS    = 10_000      # Simulation runs per scenario\n",
    "QUARTERS_AHEAD   = 8           # 2-year projection\n",
    "\n",
    "# \u2500\u2500 Anchor: published MTA evasion loss \u2500\u2500\n",
    "# CBC (Sept 2025): MTA lost $918M to bus+subway evasion in 2024\n",
    "# Bus share: $568M (61.9%), Subway share: $350M (38.1%)\n",
    "# This serves as a sanity check on our simulation outputs\n",
    "PUBLISHED_ANNUAL_LOSS = 918e6\n",
    "print(f\"\ud83d\udccc Published MTA annual evasion loss (2024): ${PUBLISHED_ANNUAL_LOSS/1e6:.0f}M\")\n",
    "print(f\"   Our simulation should produce comparable quarterly figures (~${PUBLISHED_ANNUAL_LOSS/4/1e6:.0f}M/quarter gross)\")\n",
    "\n",
    "# \u2500\u2500 Baseline from our data \u2500\u2500\n",
    "avg_evasion_rate = q['evasion_rate'].mean()\n",
    "print(f\"\\nOur data \u2014 avg evasion rate: {avg_evasion_rate:.2%}\")\n",
    "\n",
    "# \u2500\u2500 Use ridership from data if available, else estimate from published loss \u2500\u2500\n",
    "if ridership_cols:\n",
    "    avg_ridership     = q[ridership_cols[0]].mean()\n",
    "    total_ridership_q = q[ridership_cols[0]].sum()\n",
    "    print(f\"   Avg quarterly ridership (per route): {avg_ridership:,.0f}\")\n",
    "    print(f\"   Total ridership in table: {total_ridership_q:,.0f}\")\n",
    "else:\n",
    "    # Back-calculate from published loss:\n",
    "    # $918M/yr = evaded_trips/yr \u00d7 $2.90\n",
    "    # evaded_trips/yr = 316.6M; if avg evasion = 25%, total_trips = 1.27B/yr\n",
    "    total_ridership_q = (PUBLISHED_ANNUAL_LOSS / FARE / avg_evasion_rate) / 4\n",
    "    print(f\"   Ridership estimated from published loss: {total_ridership_q:,.0f} / quarter\")\n",
    "\n",
    "# \u2500\u2500 Gross revenue check \u2500\u2500\n",
    "gross_annual_check = total_ridership_q * 4 * avg_evasion_rate * FARE\n",
    "print(f\"\\n\ud83d\udcca Gross annual loss implied by our data: ${gross_annual_check/1e6:.1f}M\")\n",
    "print(f\"   (Published: $918M \u2014 {'\u2705 reasonable' if 100 < gross_annual_check/1e6 < 5000 else '\u26a0\ufe0f  check evasion rate or ridership scale'})\")\n",
    "\n",
    "# \u2500\u2500 Scenario Parameters \u2500\u2500\n",
    "# Anchored to real MTA evidence:\n",
    "# - Gate guards at 208 stations \u2192 subway evasion down 26% in 6 months\n",
    "# - Exit gate delay (15 sec) \u2192 gate evasion down 40% in pilot\n",
    "# - EAGLE team bus enforcement \u2192 bus evasion down 9.1% in 6 months\n",
    "scenarios = {\n",
    "    'Pessimistic': {\n",
    "        'evasion_reduction_mean': 0.10,\n",
    "        'evasion_reduction_std':  0.05,\n",
    "        'enforcement_cost_pct':   0.60,\n",
    "        'description': 'Minimal deterrence, high enforcement overhead'\n",
    "    },\n",
    "    'Baseline': {\n",
    "        'evasion_reduction_mean': 0.30,   # ~matching MTA 2024 gate guard results\n",
    "        'evasion_reduction_std':  0.08,\n",
    "        'enforcement_cost_pct':   0.40,\n",
    "        'description': 'Moderate success \u2014 consistent with 2024 gate guard deployment'\n",
    "    },\n",
    "    'Optimistic': {\n",
    "        'evasion_reduction_mean': 0.55,   # OMNY 85%+ adoption + targeted enforcement\n",
    "        'evasion_reduction_std':  0.10,\n",
    "        'enforcement_cost_pct':   0.25,\n",
    "        'description': 'Strong deterrence + OMNY expansion (85%+ adoption)'\n",
    "    },\n",
    "}\n",
    "\n",
    "np.random.seed(42)\n",
    "results = {}\n",
    "\n",
    "for scenario_name, params in scenarios.items():\n",
    "    quarterly_net = np.zeros((N_SIMULATIONS, QUARTERS_AHEAD))\n",
    "\n",
    "    for sim in range(N_SIMULATIONS):\n",
    "        for qtr in range(QUARTERS_AHEAD):\n",
    "            reduction = np.clip(\n",
    "                np.random.normal(params['evasion_reduction_mean'],\n",
    "                                 params['evasion_reduction_std']), 0, 0.95)\n",
    "\n",
    "            ridership_multiplier = max(1 + np.random.normal(0.005, 0.02) * (qtr + 1), 0.8)\n",
    "            sim_ridership = total_ridership_q * ridership_multiplier\n",
    "\n",
    "            evaded_trips    = sim_ridership * avg_evasion_rate\n",
    "            recovered_trips = evaded_trips * reduction\n",
    "            gross_revenue   = recovered_trips * FARE\n",
    "            net_revenue     = gross_revenue * (1 - params['enforcement_cost_pct'])\n",
    "            quarterly_net[sim, qtr] = net_revenue\n",
    "\n",
    "    cumulative = quarterly_net.cumsum(axis=1)\n",
    "    results[scenario_name] = {\n",
    "        'quarterly':   quarterly_net,\n",
    "        'cumulative':  cumulative,\n",
    "        'total_mean':  cumulative[:, -1].mean(),\n",
    "        'total_p5':    np.percentile(cumulative[:, -1],  5),\n",
    "        'total_p25':   np.percentile(cumulative[:, -1], 25),\n",
    "        'total_p50':   np.percentile(cumulative[:, -1], 50),\n",
    "        'total_p75':   np.percentile(cumulative[:, -1], 75),\n",
    "        'total_p95':   np.percentile(cumulative[:, -1], 95),\n",
    "    }\n",
    "\n",
    "# \u2500\u2500 Summary table \u2500\u2500\n",
    "print(f\"\\n{'='*85}\")\n",
    "print(f\"{'MONTE CARLO REVENUE RECOVERY \u2014 8-QUARTER PROJECTION':^85}\")\n",
    "print(f\"{'='*85}\")\n",
    "print(f\"  {'Scenario':<15} {'Mean':>14} {'P5':>14} {'P25':>14} {'Median':>14} {'P95':>14}\")\n",
    "print(f\"  {'-'*75}\")\n",
    "for name, r in results.items():\n",
    "    print(f\"  {name:<15} \"\n",
    "          f\"${r['total_mean']/1e6:>10.1f}M \"\n",
    "          f\"${r['total_p5']/1e6:>10.1f}M \"\n",
    "          f\"${r['total_p25']/1e6:>10.1f}M \"\n",
    "          f\"${r['total_p50']/1e6:>10.1f}M \"\n",
    "          f\"${r['total_p95']/1e6:>10.1f}M\")\n",
    "\n",
    "print(f\"\\n\ud83d\udccc For reference: MTA published $918M annual loss (2024)\")\n",
