   "source": [
    "# Cell 3: Map your columns to pipeline variables\n",
    "# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "# INSTRUCTIONS: After running Cell 2, update the right-hand side of\n",
    "# each mapping below to match YOUR actual column names. Set to None\n",
    "# if the column doesn't exist \u2014 the pipeline will synthesize proxies.\n",
    "# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "COLUMN_MAP = {\n",
    "    # \u2500\u2500 Identifiers \u2500\u2500\n",
    "    \"route\":            \"route_id\",\n",
    "    \"date\":             None,\n",
    "    \"borough\":          \"borough\",\n",
    "\n",
    "    # \u2500\u2500 Ridership / Volume \u2500\u2500\n",
    "    \"ridership\":        None,\n",
    "    \"total_trips\":      \"number_of_trips_passing_wait\",\n",
    "    \"scheduled_trips\":  \"number_of_scheduled_trips\",\n",
    "\n",
    "    # \u2500\u2500 Performance \u2500\u2500\n",
    "    \"otp\":              None,\n",
    "    \"wait_assessment\":  \"wait_assessment\",\n",
    "    \"mean_distance_bf\": None,\n",
    "\n",
    "    # \u2500\u2500 Fare Collection \u2500\u2500\n",
    "    \"fare_evasion\":     \"Fare Evasion\",\n",
    "    \"omny_taps\":        None,\n",
    "    \"metrocard_swipes\": None,\n",
    "    \"fare_revenue\":     None\n",
    "}\n",
    "\n",
    "# \u2500\u2500 Auto-detect helper: fuzzy-match column names \u2500\u2500\n",
    "def auto_map(df, col_map):\n",
    "    \"\"\"Attempt to match map keys to actual columns via substring matching.\"\"\"\n",
    "    actual = {c.lower().replace(\" \", \"_\").replace(\"-\", \"_\"): c for c in df.columns}\n",
    "    hints = {\n",
    "        \"route\":           [\"route\", \"line\", \"bus_route\"],\n",
    "        \"date\":            [\"date\", \"month\", \"period\", \"year_month\"],\n",
    "        \"borough\":         [\"borough\", \"boro\", \"district\"],\n",
    "        \"ridership\":       [\"ridership\", \"riders\", \"passenger\"],\n",
    "        \"total_trips\":     [\"actual_trip\", \"total_trip\", \"trips_completed\"],\n",
    "        \"scheduled_trips\": [\"scheduled_trip\", \"planned_trip\"],\n",
    "        \"otp\":             [\"on_time\", \"otp\", \"punctual\"],\n",
    "        \"wait_assessment\": [\"wait_assess\", \"wait_pct\"],\n",
    "        \"mean_distance_bf\":[\"mdbf\", \"mean_distance\", \"breakdown\"],\n",
    "        \"fare_evasion\":    [\"evasion\", \"fare_evasion\"],\n",
    "        \"omny_taps\":       [\"omny\", \"contactless\"],\n",
    "        \"metrocard_swipes\":[\"metrocard\", \"swipe\"],\n",
    "        \"fare_revenue\":    [\"revenue\", \"fare_rev\"],\n",
    "    }\n",
    "\n",
    "    mapped = {}\n",
    "    for key, patterns in hints.items():\n",
    "        if col_map.get(key):\n",
    "            mapped[key] = col_map[key]\n",
    "            continue\n",
    "        for pat in patterns:\n",
    "            for norm, orig in actual.items():\n",
    "                if pat in norm:\n",
    "                    mapped[key] = orig\n",
    "                    break\n",
    "            if key in mapped:\n",
    "                break\n",
    "    return mapped\n",
    "\n",
    "COL = auto_map(df_raw, COLUMN_MAP)\n",
    "\n",
    "print(\"AUTO-DETECTED COLUMN MAPPING:\")\n",
    "for k, v in COL.items():\n",
    "    print(f\"  {k:<20} \u2192 {v}\")\n",
    "\n",
    "unmapped = [k for k in COLUMN_MAP if k not in COL]\n",
    "if unmapped:\n",
    "    print(f\"\\n\u26a0\ufe0f  Unmapped (will be synthesized): {unmapped}\")\n",
    "\n"
   ]
  },
