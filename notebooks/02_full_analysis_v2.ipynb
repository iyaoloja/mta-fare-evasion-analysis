    "# Cell 8: Classification \u2014 Classify routes by evasion risk tier\n",
    "\n",
    "clf_target = \"high_evasion\"\n",
    "clf_df = q[features + [clf_target]].dropna()\n",
    "X_clf = clf_df[features]\n",
    "y_clf = clf_df[clf_target]\n",
    "\n",
    "X_train_c, X_test_c, y_train_c, y_test_c = train_test_split(\n",
    "    X_clf, y_clf, test_size=0.2, random_state=42, stratify=y_clf)\n",
    "\n",
    "scaler_c = StandardScaler()\n",
    "X_train_cs = scaler_c.fit_transform(X_train_c)\n",
    "X_test_cs  = scaler_c.transform(X_test_c)\n",
    "\n",
    "classifiers = {\n",
    "    \"Logistic Regression\": LogisticRegression(max_iter=1000, random_state=42),\n",
    "    \"Random Forest\":       RandomForestClassifier(n_estimators=300, max_depth=8, random_state=42),\n",
    "    \"Gradient Boosting\":   GradientBoostingClassifier(n_estimators=200, max_depth=5, random_state=42),\n",
    "}\n",
    "\n",
    "print(\"\u2500\u2500 Classification Model Comparison \u2500\u2500\\n\")\n",
    "best_auc, best_name, best_model = 0, \"\", None\n",
    "roc_data = {}\n",
    "\n",
    "for name, clf in classifiers.items():\n",
    "    clf.fit(X_train_cs, y_train_c)\n",
    "    y_pred  = clf.predict(X_test_cs)\n",
    "    y_proba = clf.predict_proba(X_test_cs)[:, 1]\n",
    "    acc     = accuracy_score(y_test_c, y_pred)\n",
    "    auc     = roc_auc_score(y_test_c, y_proba)\n",
    "    roc_data[name] = roc_curve(y_test_c, y_proba)\n",
    "    \n",
    "    print(f\"\u25b8 {name}\")\n",
    "    print(f\"  Accuracy: {acc:.4f}  |  AUC-ROC: {auc:.4f}\")\n",
    "    print(classification_report(y_test_c, y_pred, target_names=[\"Low Risk\",\"High Risk\"]))\n",
    "    \n",
    "    if auc > best_auc:\n",
    "        best_auc, best_name, best_model = auc, name, clf\n",
    "\n",
    "# \u2500\u2500 ROC Curves \u2500\u2500\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "\n",
    "for name, (fpr, tpr, _) in roc_data.items():\n",
    "    axes[0].plot(fpr, tpr, linewidth=2, label=name)\n",
    "axes[0].plot([0,1],[0,1], \"--\", color=\"gray\")\n",
    "axes[0].set_title(\"ROC Curves \u2014 Route Risk Classification\", fontweight=\"bold\")\n",
    "axes[0].set_xlabel(\"False Positive Rate\")\n",
    "axes[0].set_ylabel(\"True Positive Rate\")\n",
    "axes[0].legend()\n",
    "\n",
    "# \u2500\u2500 Confusion matrix for best model \u2500\u2500\n",
    "y_pred_best = best_model.predict(X_test_cs)\n",
    "cm = confusion_matrix(y_test_c, y_pred_best)\n",
    "sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\", xticklabels=[\"Low\",\"High\"],\n",
    "            yticklabels=[\"Low\",\"High\"], ax=axes[1])\n",
    "axes[1].set_title(f\"Confusion Matrix \u2014 {best_name}\", fontweight=\"bold\")\n",
    "axes[1].set_xlabel(\"Predicted\")\n",
    "axes[1].set_ylabel(\"Actual\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"classification_results.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "\n",
    "# \u2500\u2500 Route Risk Scoring \u2500\u2500\n",
    "X_all_scaled = scaler_c.transform(X_clf)\n",
    "q_scored = clf_df.copy()\n",
    "q_scored[\"risk_probability\"] = best_model.predict_proba(X_all_scaled)[:, 1]\n",
    "q_scored[\"risk_tier\"] = pd.cut(q_scored[\"risk_probability\"],\n",
    "                               bins=[0, 0.33, 0.66, 1.0],\n",
    "                               labels=[\"Low\", \"Medium\", \"High\"])\n",
    "\n",
    "print(f\"\\n\u2705 Best model: {best_name} (AUC={best_auc:.4f})\")\n",
    "print(f\"\\nRisk Tier Distribution:\")\n",
    "print(q_scored[\"risk_tier\"].value_counts().to_string())\n"
   ]
